  "publicApiSurface": [
    "kmagent start - Start the agent service",
    "kmagent stop - Stop the agent service",
    "kubeagent - Kubernetes agent binary",
    "KM_API_KEY - API key for authentication",
    "KM_COLLECTOR_ENDPOINT - OpenTelemetry exporter endpoint",
    "KM_COLLECTOR_CONFIG - Path to collector configuration file",
    "KM_CONFIG_CHECK_INTERVAL - Interval for remote config updates",
    "KM_UPDATE_ENDPOINT - Agent config update endpoint",
    "KM_DOCKER_MODE - Enable Docker mode configuration",
    "Helm chart: kloudmate/km-kube-agent",
